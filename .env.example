# Copy this file to .env.local and fill in your values.
# Restart dev servers after changing env vars.

# --- Local web (Vite) ---
VITE_GITHUB_REPO=your-username/tpd-weekly-update
VITE_BASE_PATH=/tpd-weekly-update/

# Optional: identity fallback when the API is not running (Vite dev only)
# VITE_DEV_USER_EMAIL=you@axon.com

# --- Local API (server/index.js) ---
DEV_USER_EMAIL=you@axon.com
GITHUB_REPO=your-username/tpd-weekly-update
GITHUB_BRANCH=main
# Fine-grained or classic PAT with Contents write on the repo
GITHUB_TOKEN=ghp_your_token_here
